+bool		hnsw_trace_enabled;
 static relopt_kind hnsw_relopt_kind;
 
+/*
+ * Track distinct element pages accessed during scan
+ */
+void
+HnswTraceRecordElementPage(HnswTraceStats * trace, BlockNumber blkno)
+{
+	if (trace == NULL)
+		return;
+
+	trace->index_element_loads++;
+
+	/* Track page runs: a new run starts when page differs from last */
+	if (trace->index_element_loads == 1 || blkno != trace->last_element_page)
+		trace->index_element_page_runs++;
+	trace->last_element_page = blkno;
+
+	/* Track distinct pages via linear scan of small array */
+	for (int i = 0; i < trace->index_element_distinct_pages; i++)
+	{
+		if (trace->element_pages_seen[i] == blkno)
+			return;
+	}
+	if (trace->index_element_distinct_pages < trace->element_pages_capacity)
+		trace->element_pages_seen[trace->index_element_distinct_pages] = blkno;
+	trace->index_element_distinct_pages++;
+}
+
+/*
+ * Track distinct neighbor pages accessed during scan
+ */
+void
+HnswTraceRecordNeighborPage(HnswTraceStats * trace, BlockNumber blkno)
+{
+	if (trace == NULL)
+		return;
+
+	trace->index_neighbor_loads++;
+
+	if (trace->index_neighbor_loads == 1 || blkno != trace->last_neighbor_page)
+		trace->index_neighbor_page_runs++;
+	trace->last_neighbor_page = blkno;
+
+	for (int i = 0; i < trace->index_neighbor_distinct_pages; i++)
+	{
+		if (trace->neighbor_pages_seen[i] == blkno)
+			return;
+	}
+	if (trace->index_neighbor_distinct_pages < trace->neighbor_pages_capacity)
+		trace->neighbor_pages_seen[trace->index_neighbor_distinct_pages] = blkno;
+	trace->index_neighbor_distinct_pages++;
+}
+
 /*
  * Assign a tranche ID for our LWLocks. This only needs to be done by one
  * backend, as the tranche ID is remembered in shared memory.
@@ -108,6 +161,10 @@ HnswInit(void)
 							 NULL, &hnsw_scan_mem_multiplier,
 							 1, 1, 1000, PGC_USERSET, 0, NULL, NULL, NULL);
 
+	DefineCustomBoolVariable("hnsw.trace", "Enables detailed per-query trace output for HNSW scans",
+							  NULL, &hnsw_trace_enabled,
+							  false, PGC_USERSET, 0, NULL, NULL, NULL);
+
 	MarkGUCPrefixReserved("hnsw");
 }
 
